{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "sourceMap": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "removeComments": true
  },
  "exclude": [
    "node_modules",
    "tests",
    "src/**/__tests__/*",
    "src/**/*.test.ts"
  ],
  "include": [
    "src/**/*"
  ]
}