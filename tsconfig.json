{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "paths": {
      "@nuclie/adapter-core": ["./packages/nuclie-adapter-core/src/index.js", "./packages/nuclie-adapter-core/src/index.ts"],
      "@nuclie/adapter-core/*": ["./packages/nuclie-adapter-core/*"]
    }
  },
  "include": [
    "src/**/*",
    "extensions/**/*",
    "tests/**/*",
    "benchmarks/**/*"
  ]
}